generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(uuid())
  sumupId   String?   @unique
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  slug      String?   @unique
  products  Product[]

  @@index([name])
  @@index([slug])
}

model Product {
  id                 String              @id @default(uuid())
  sumupId            String?             @unique
  name               String
  price              Decimal             @db.Decimal(10, 2)
  purchasePrice      Decimal?            @db.Decimal(10, 2)
  unit               String              @default("ks")
  categoryId         String?
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  vatRate            Decimal             @default(21) @db.Decimal(5, 2)
  description        String?
  eshopActive        Boolean             @default(false)
  imageUrls          String[]            @default([])
  isFeatured         Boolean             @default(false)
  shortDescription   String?
  slug               String?             @unique
  customerOrderItems CustomerOrderItem[]
  deliveryNoteItems  DeliveryNoteItem[]
  EshopCartItem      EshopCartItem[]
  inventoryItems     InventoryItem[]
  issuedInvoiceItems IssuedInvoiceItem[]
  category           Category?           @relation(fields: [categoryId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  receiptItems       ReceiptItem[]
  reservations       Reservation[]
  transactionItems   TransactionItem[]
  eshopVariants      EshopVariant[]

  @@index([name])
  @@index([categoryId])
  @@index([eshopActive])
  @@index([slug])
}

model InventoryItem {
  id                String             @id @default(uuid())
  productId         String
  quantity          Decimal            @db.Decimal(10, 3)
  unit              String
  supplierId        String?
  purchasePrice     Decimal            @db.Decimal(10, 2)
  receiptId         String?
  transactionId     String?
  date              DateTime           @default(now())
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  vatRate           Decimal            @default(21) @db.Decimal(5, 2)
  deliveryNoteItems DeliveryNoteItem[]
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  receipt           Receipt?           @relation(fields: [receiptId], references: [id])
  supplier          Supplier?          @relation(fields: [supplierId], references: [id])
  transaction       Transaction?       @relation(fields: [transactionId], references: [id])
  receiptItems      ReceiptItem[]

  @@index([productId])
  @@index([date])
  @@index([receiptId])
  @@index([transactionId])
}

model Supplier {
  id             String          @id @default(uuid())
  name           String          @unique
  contact        String?
  email          String?
  phone          String?
  ico            String?
  dic            String?
  bankAccount    String?
  address        String?
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  website        String?
  entityType     String          @default("company")
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  receipts       Receipt[]
  transactions   Transaction[]

  @@index([name])
}

model Customer {
  id             String          @id @default(uuid())
  name           String          @unique
  contact        String?
  email          String?
  phone          String?
  ico            String?
  dic            String?
  bankAccount    String?
  address        String?
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entityType     String          @default("company")
  customerOrders CustomerOrder[]
  deliveryNotes  DeliveryNote[]
  issuedInvoices IssuedInvoice[]
  transactions   Transaction[]

  @@index([name])
}

model Transaction {
  id                    String            @id @default(uuid())
  sumupId               String?           @unique
  receiptId             String?
  transactionCode       String            @unique
  totalAmount           Decimal           @db.Decimal(10, 2)
  invoiceType           String            @default("issued")
  supplierId            String?
  supplierName          String?
  supplierICO           String?
  supplierDIC           String?
  supplierAddress       String?
  customerId            String?
  customerName          String?
  customerICO           String?
  customerDIC           String?
  customerAddress       String?
  paymentType           String
  status                String            @default("completed")
  transactionDate       DateTime          @default(now())
  note                  String?
  attachmentUrl         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  sumupTransactionCode  String?
  totalAmountWithoutVat Decimal           @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal           @default(0) @db.Decimal(10, 2)
  deliveryNote          DeliveryNote?
  inventoryItems        InventoryItem[]
  issuedInvoice         IssuedInvoice?
  customer              Customer?         @relation(fields: [customerId], references: [id])
  supplier              Supplier?         @relation(fields: [supplierId], references: [id])
  items                 TransactionItem[]

  @@index([transactionCode])
  @@index([transactionDate])
  @@index([customerId])
  @@index([supplierId])
  @@index([invoiceType])
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String?
  productName   String?
  quantity      Decimal     @db.Decimal(10, 3)
  unit          String
  price         Decimal?    @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  priceWithVat  Decimal?    @db.Decimal(10, 2)
  vatAmount     Decimal?    @db.Decimal(10, 2)
  vatRate       Decimal     @default(21) @db.Decimal(5, 2)
  product       Product?    @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([productId])
}

model Settings {
  id                        String   @id @default("default")
  companyName               String   @default("")
  ico                       String   @default("")
  dic                       String   @default("")
  address                   String   @default("")
  phone                     String   @default("")
  email                     String   @default("")
  bankAccount               String   @default("")
  logo                      String?
  lastIssuedInvoiceNumber   Int      @default(0)
  lastIssuedInvoiceYear     Int      @default(0)
  lastReceivedInvoiceNumber Int      @default(0)
  lastPurchaseOrderNumber   Int      @default(0)
  lastPurchaseOrderYear     Int      @default(0)
  lastReceiptNumber         Int      @default(0)
  lastReceiptYear           Int      @default(0)
  lastDeliveryNoteNumber    Int      @default(0)
  lastDeliveryNoteYear      Int      @default(0)
  lastCustomerOrderNumber   Int      @default(0)
  lastCustomerOrderYear     Int      @default(0)
  allowNegativeStock        Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  lastTransactionNumber     Int      @default(0)
  lastTransactionYear       Int      @default(0)
  defaultVatRate            Decimal  @default(21) @db.Decimal(5, 2)
  isVatPayer                Boolean  @default(true)
  eshopApiKey               String   @default("")
}

model PurchaseOrder {
  id                    String              @id @default(uuid())
  orderNumber           String              @unique
  supplierId            String?
  supplierName          String?
  supplierICO           String?
  supplierDIC           String?
  supplierAddress       String?
  orderDate             DateTime            @default(now())
  expectedDate          DateTime?
  note                  String?
  status                String              @default("pending")
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  supplierBankAccount   String?
  supplierContactPerson String?
  supplierEmail         String?
  supplierPhone         String?
  supplierWebsite       String?
  supplierEntityType    String?
  discountAmount        Decimal?            @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?            @db.Decimal(10, 2)
  totalAmount           Decimal?            @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal?            @db.Decimal(10, 2)
  totalVatAmount        Decimal?            @db.Decimal(10, 2)
  supplier              Supplier?           @relation(fields: [supplierId], references: [id])
  items                 PurchaseOrderItem[]
  receipts              Receipt[]
  invoice               ReceivedInvoice?

  @@index([orderNumber])
  @@index([supplierId])
  @@index([orderDate])
  @@index([status])
}

model PurchaseOrderItem {
  id                      String        @id @default(uuid())
  purchaseOrderId         String
  productId               String?
  productName             String?
  quantity                Decimal       @db.Decimal(10, 3)
  alreadyReceivedQuantity Decimal       @default(0) @db.Decimal(10, 3)
  unit                    String
  expectedPrice           Decimal?      @db.Decimal(10, 2)
  createdAt               DateTime      @default(now())
  priceWithVat            Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount               Decimal       @default(0) @db.Decimal(10, 2)
  vatRate                 Decimal       @default(21) @db.Decimal(5, 2)
  product                 Product?      @relation(fields: [productId], references: [id])
  purchaseOrder           PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}

model Receipt {
  id                String           @id @default(uuid())
  receiptNumber     String           @unique
  purchaseOrderId   String?
  supplierId        String?
  supplierName      String?
  supplierICO       String?
  supplierDIC       String?
  supplierAddress   String?
  receiptDate       DateTime         @default(now())
  note              String?
  status            String           @default("draft")
  processedAt       DateTime?
  stornoReason      String?
  stornoAt          DateTime?
  stornoBy          String?
  receivedInvoiceId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  inventoryItems    InventoryItem[]
  purchaseOrder     PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  receivedInvoice   ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id])
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  items             ReceiptItem[]

  @@index([receiptNumber])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([receivedInvoiceId])
  @@index([receiptDate])
  @@index([status])
}

model ReceiptItem {
  id               String         @id @default(uuid())
  receiptId        String
  productId        String?
  productName      String?
  quantity         Decimal        @db.Decimal(10, 3)
  receivedQuantity Decimal?       @db.Decimal(10, 3)
  unit             String
  purchasePrice    Decimal        @db.Decimal(10, 2)
  inventoryItemId  String?
  createdAt        DateTime       @default(now())
  priceWithVat     Decimal        @default(0) @db.Decimal(10, 2)
  vatAmount        Decimal        @default(0) @db.Decimal(10, 2)
  vatRate          Decimal        @default(21) @db.Decimal(5, 2)
  inventoryItem    InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  product          Product?       @relation(fields: [productId], references: [id])
  receipt          Receipt        @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([productId])
  @@index([inventoryItemId])
}

model ReceivedInvoice {
  id                    String         @id @default(uuid())
  invoiceNumber         String         @unique
  purchaseOrderId       String?        @unique
  isTemporary           Boolean        @default(false)
  invoiceDate           DateTime
  dueDate               DateTime?
  totalAmount           Decimal        @db.Decimal(10, 2)
  paymentType           String         @default("transfer")
  attachmentUrl         String?
  note                  String?
  status                String         @default("active")
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  supplierAddress       String?
  supplierBankAccount   String?
  supplierContactPerson String?
  supplierDic           String?
  supplierEmail         String?
  supplierIco           String?
  supplierName          String?
  supplierPhone         String?
  supplierWebsite       String?
  constantSymbol        String?
  specificSymbol        String?
  variableSymbol        String?
  supplierEntityType    String?        @default("company")
  supplierNote          String?
  discountAmount        Decimal?       @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?       @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal        @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal        @default(0) @db.Decimal(10, 2)
  receipts              Receipt[]
  purchaseOrder         PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([invoiceNumber])
  @@index([purchaseOrderId])
  @@index([invoiceDate])
  @@index([isTemporary])
}

model DeliveryNote {
  id              String             @id @default(uuid())
  deliveryNumber  String             @unique
  transactionId   String?            @unique
  customerOrderId String?
  customerId      String?
  customerName    String?
  deliveryDate    DateTime           @default(now())
  note            String?
  status          String             @default("draft")
  processedAt     DateTime?
  stornoReason    String?
  stornoAt        DateTime?
  stornoBy        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  customer        Customer?          @relation(fields: [customerId], references: [id])
  customerOrder   CustomerOrder?     @relation(fields: [customerOrderId], references: [id])
  transaction     Transaction?       @relation(fields: [transactionId], references: [id])
  items           DeliveryNoteItem[]
  issuedInvoice   IssuedInvoice?

  @@index([deliveryNumber])
  @@index([transactionId])
  @@index([customerOrderId])
  @@index([customerId])
  @@index([deliveryDate])
  @@index([status])
}

model DeliveryNoteItem {
  id              String         @id @default(uuid())
  deliveryNoteId  String
  productId       String?
  productName     String?
  quantity        Decimal        @db.Decimal(10, 3)
  orderedQuantity Decimal?       @db.Decimal(10, 3)
  unit            String
  inventoryItemId String?
  createdAt       DateTime       @default(now())
  deliveryNote    DeliveryNote   @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  product         Product?       @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
  @@index([productId])
  @@index([inventoryItemId])
}

model CustomerOrder {
  id                    String              @id @default(uuid())
  orderNumber           String              @unique
  customerId            String?
  customerName          String?
  customerEmail         String?
  customerPhone         String?
  customerAddress       String?
  orderDate             DateTime            @default(now())
  totalAmount           Decimal             @db.Decimal(10, 2)
  note                  String?
  status                String              @default("new")
  paidAt                DateTime?
  shippedAt             DateTime?
  sumupTransactionId    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  stornoAt              DateTime?
  stornoBy              String?
  stornoReason          String?
  customerEntityType    String?
  discountAmount        Decimal?            @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?            @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal             @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal             @default(0) @db.Decimal(10, 2)
  eshopOrderId          String?             @unique
  source                String              @default("internal")
  eshopAddressId        String?
  eshopUserId           String?
  stripePaymentIntent   String?
  stripeSessionId       String?             @unique
  trackingNumber        String?
  carrier               String?
  paymentReference      String?
  customer              Customer?           @relation(fields: [customerId], references: [id])
  EshopUser             EshopUser?          @relation(fields: [eshopUserId], references: [id])
  items                 CustomerOrderItem[]
  deliveryNotes         DeliveryNote[]
  issuedInvoice         IssuedInvoice?
  reservations          Reservation[]
  webhookLogs           EshopWebhookLog[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([orderDate])
  @@index([status])
  @@index([sumupTransactionId])
  @@index([eshopUserId])
  @@index([source])
  @@index([stripeSessionId])
  @@index([eshopOrderId])
}

model CustomerOrderItem {
  id              String        @id @default(uuid())
  customerOrderId String
  productId       String?
  productName     String?
  quantity        Decimal       @db.Decimal(10, 3)
  shippedQuantity Decimal       @default(0) @db.Decimal(10, 3)
  unit            String
  price           Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  priceWithVat    Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  vatRate         Decimal       @default(21) @db.Decimal(5, 2)
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@index([customerOrderId])
  @@index([productId])
}

model Reservation {
  id              String        @id @default(uuid())
  customerOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(10, 3)
  unit            String
  status          String        @default("active")
  createdAt       DateTime      @default(now())
  cancelledAt     DateTime?
  fulfilledAt     DateTime?
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
  @@index([productId])
  @@index([status])
}

model IssuedInvoice {
  id                    String              @id @default(uuid())
  invoiceNumber         String              @unique
  transactionId         String?             @unique
  customerOrderId       String?             @unique
  deliveryNoteId        String?             @unique
  customerId            String?
  customerName          String?
  invoiceDate           DateTime            @default(now())
  dueDate               DateTime?
  totalAmount           Decimal             @db.Decimal(10, 2)
  paymentType           String              @default("card")
  paymentStatus         String              @default("paid")
  note                  String?
  status                String              @default("active")
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  constantSymbol        String?
  specificSymbol        String?
  variableSymbol        String?
  customerAddress       String?
  customerBankAccount   String?
  customerContactPerson String?
  customerDic           String?
  customerEmail         String?
  customerIco           String?
  customerPhone         String?
  customerWebsite       String?
  customerEntityType    String?
  discountAmount        Decimal?            @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?            @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal             @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal             @default(0) @db.Decimal(10, 2)
  creditNotes           CreditNote[]
  customer              Customer?           @relation(fields: [customerId], references: [id])
  customerOrder         CustomerOrder?      @relation(fields: [customerOrderId], references: [id])
  deliveryNote          DeliveryNote?       @relation(fields: [deliveryNoteId], references: [id])
  transaction           Transaction?        @relation(fields: [transactionId], references: [id])
  items                 IssuedInvoiceItem[]

  @@index([invoiceNumber])
  @@index([transactionId])
  @@index([customerOrderId])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@index([status])
}

model IssuedInvoiceItem {
  id              String        @id @default(uuid())
  issuedInvoiceId String
  productId       String?
  productName     String?
  quantity        Decimal       @db.Decimal(10, 3)
  unit            String
  price           Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  priceWithVat    Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  vatRate         Decimal       @default(21) @db.Decimal(5, 2)
  issuedInvoice   IssuedInvoice @relation(fields: [issuedInvoiceId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@index([issuedInvoiceId])
  @@index([productId])
}

model CreditNote {
  id                    String           @id @default(uuid())
  creditNoteNumber      String           @unique
  issuedInvoiceId       String
  customerId            String?
  customerName          String?
  customerEntityType    String?
  customerEmail         String?
  customerPhone         String?
  customerAddress       String?
  customerIco           String?
  customerDic           String?
  creditNoteDate        DateTime         @default(now())
  totalAmount           Decimal          @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal          @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal          @default(0) @db.Decimal(10, 2)
  reason                String?
  note                  String?
  status                String           @default("active")
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  issuedInvoice         IssuedInvoice    @relation(fields: [issuedInvoiceId], references: [id], onDelete: Cascade)
  items                 CreditNoteItem[]

  @@index([creditNoteNumber])
  @@index([issuedInvoiceId])
  @@index([customerId])
  @@index([creditNoteDate])
  @@index([status])
}

model CreditNoteItem {
  id           String     @id @default(uuid())
  creditNoteId String
  productId    String?
  productName  String?
  quantity     Decimal    @db.Decimal(10, 3)
  unit         String
  price        Decimal    @db.Decimal(10, 2)
  vatRate      Decimal    @default(21) @db.Decimal(5, 2)
  vatAmount    Decimal    @default(0) @db.Decimal(10, 2)
  priceWithVat Decimal    @default(0) @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model DocumentSeries {
  id           String   @id @default(uuid())
  documentType String
  year         Int
  lastNumber   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([documentType, year])
  @@index([documentType])
}

model Inventura {
  id               String          @id @default(uuid())
  inventuraNumber  String          @unique
  inventuraDate    DateTime        @default(now())
  note             String?
  totalProducts    Int             @default(0)
  checkedProducts  Int             @default(0)
  differencesCount Int             @default(0)
  surplusCount     Int             @default(0)
  shortageCount    Int             @default(0)
  status           String          @default("completed")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            InventuraItem[]

  @@index([inventuraNumber])
  @@index([inventuraDate])
  @@index([status])
}

model InventuraItem {
  id             String    @id @default(uuid())
  inventuraId    String
  productId      String
  productName    String
  unit           String
  category       String?
  systemStock    Decimal   @db.Decimal(10, 3)
  actualStock    Decimal   @db.Decimal(10, 3)
  difference     Decimal   @db.Decimal(10, 3)
  differenceType String    @default("none")
  createdAt      DateTime  @default(now())
  inventura      Inventura @relation(fields: [inventuraId], references: [id], onDelete: Cascade)

  @@index([inventuraId])
  @@index([productId])
}

model BlogPost {
  id          String    @id
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  @@index([published])
  @@index([slug])
}

model EshopAddress {
  id         String    @id
  userId     String
  fullName   String
  line1      String
  line2      String?
  city       String
  postalCode String
  country    String    @default("CZ")
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  EshopUser  EshopUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EshopCart {
  id            String          @id
  userId        String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  EshopUser     EshopUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  EshopCartItem EshopCartItem[]
}

model EshopCartItem {
  id        String    @id
  cartId    String
  productId String
  quantity  Int       @default(1)
  EshopCart EshopCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model EshopEmailVerificationToken {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  EshopUser EshopUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EshopPasswordResetToken {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  EshopUser EshopUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EshopSetting {
  key       String   @id
  value     String
  updatedAt DateTime
}

model EshopUser {
  id                          String                        @id
  email                       String                        @unique
  name                        String?
  phone                       String?
  passwordHash                String?
  role                        String                        @default("CUSTOMER")
  emailVerified               DateTime?
  newsletter                  Boolean                       @default(false)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime
  CustomerOrder               CustomerOrder[]
  EshopAddress                EshopAddress[]
  EshopCart                   EshopCart?
  EshopEmailVerificationToken EshopEmailVerificationToken[]
  EshopPasswordResetToken     EshopPasswordResetToken[]

  @@index([email])
}

model ShippingMethod {
  id            String   @id
  name          String
  description   String?
  price         Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  estimatedDays String   @default("2-3")
  freeThreshold Int?
}

// ========== UŽIVATELÉ (PŘIHLÁŠENÍ DO ERP) ==========
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

// ========== API KLÍČE PRO EXTERNÍ PŘÍSTUP (E-SHOP) ==========
// ========== VARIANTY PRODUKTŮ PRO ESHOP (spravováno z ERP) ==========
model EshopVariant {
  id           String   @id @default(uuid())
  productId    String
  name         String
  price        Decimal  @db.Decimal(10, 2)
  variantValue Float?   // Množství na variantu (100, 30, 3.5 …)
  variantUnit  String?  // Jednotka varianty: "g" | "ml" | "ks" — null zdědí Product.unit
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String    // Popis klíče (např. "Eshop Weedej na Vercelu")
  key        String    @unique // Samotný API klíč (erp_live_xxxx...)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([key])
}

// ========== WEBHOOK LOGY (ERP → E-SHOP) ==========
model EshopWebhookLog {
  id              String        @id @default(uuid())
  customerOrderId String
  eshopOrderId    String
  erpOrderNumber  String
  event           String        @default("order-shipped")
  targetUrl       String
  payload         String        // JSON stringified (no PII)
  payloadHash     String        // SHA-256 of payload for tamper detection
  attemptCount    Int           @default(0)
  lastAttemptAt   DateTime?
  lastHttpStatus  Int?
  lastError       String?
  nextRetryAt     DateTime?
  // pending | delivered | retrying | dead
  status          String        @default("pending")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
  @@index([eshopOrderId])
  @@index([status])
  @@index([nextRetryAt])
}
