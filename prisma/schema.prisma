generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Batch {
  id              String         @id @default(uuid())
  batchNumber     String
  productId       String
  productionDate  DateTime?
  expiryDate      DateTime?
  supplierLotRef  String?
  supplierId      String?
  receivedDate    DateTime       @default(now())
  status          String         @default("active")
  // active | quarantine | recalled | expired | consumed
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  receiptItems    ReceiptItem[]
  inventoryItems  InventoryItem[]

  @@unique([batchNumber, productId])
  @@index([productId])
  @@index([status])
  @@index([expiryDate])
  @@index([batchNumber])
  @@index([receivedDate])
}

model Category {
  id        String    @id @default(uuid())
  sumupId   String?   @unique
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  slug      String?   @unique
  products  Product[]

  @@index([name])
  @@index([slug])
}

model Product {
  id                 String              @id @default(uuid())
  sumupId            String?             @unique
  name               String
  price              Decimal             @db.Decimal(10, 2)
  purchasePrice      Decimal?            @db.Decimal(10, 2)
  unit               String              @default("ks")
  categoryId         String?
  active             Boolean             @default(true)
  batchTracking      Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  vatRate            Decimal             @default(21) @db.Decimal(5, 2)
  description        String?
  eshopActive        Boolean             @default(false)
  imageUrls          String[]            @default([])
  isFeatured         Boolean             @default(false)
  shortDescription   String?
  slug               String?             @unique
  customerOrderItems CustomerOrderItem[]
  deliveryNoteItems  DeliveryNoteItem[]
  EshopCartItem      EshopCartItem[]
  inventoryItems     InventoryItem[]
  issuedInvoiceItems IssuedInvoiceItem[]
  batches            Batch[]
  category           Category?           @relation(fields: [categoryId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  receiptItems       ReceiptItem[]
  reservations       Reservation[]
  transactionItems   TransactionItem[]
  eshopVariants      EshopVariant[]

  @@index([name])
  @@index([categoryId])
  @@index([eshopActive])
  @@index([slug])
}

model InventoryItem {
  id                String             @id @default(uuid())
  productId         String
  quantity          Decimal            @db.Decimal(10, 3)
  unit              String
  supplierId        String?
  purchasePrice     Decimal            @db.Decimal(10, 2)
  receiptId         String?
  transactionId     String?
  batchId           String?
  date              DateTime           @default(now())
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  vatRate           Decimal            @default(21) @db.Decimal(5, 2)
  batch             Batch?             @relation(fields: [batchId], references: [id])
  deliveryNoteItems DeliveryNoteItem[]
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  receipt           Receipt?           @relation(fields: [receiptId], references: [id])
  supplier          Supplier?          @relation(fields: [supplierId], references: [id])
  transaction       Transaction?       @relation(fields: [transactionId], references: [id])
  receiptItems      ReceiptItem[]

  @@index([productId])
  @@index([batchId])
  @@index([date])
  @@index([receiptId])
  @@index([transactionId])
}

model Supplier {
  id             String          @id @default(uuid())
  name           String          @unique
  contact        String?
  email          String?
  phone          String?
  ico            String?
  dic            String?
  bankAccount    String?
  address        String?
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  website        String?
  entityType     String          @default("company")
  batches        Batch[]
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  receipts       Receipt[]
  transactions   Transaction[]

  @@index([name])
}

model Customer {
  id             String          @id @default(uuid())
  name           String          @unique
  contact        String?
  email          String?
  phone          String?
  ico            String?
  dic            String?
  bankAccount    String?
  address        String?
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entityType     String          @default("company")
  customerOrders CustomerOrder[]
  deliveryNotes  DeliveryNote[]
  issuedInvoices IssuedInvoice[]
  transactions   Transaction[]

  // CRM relations
  crmContacts           CrmContact[]
  crmRelationshipStatus CrmRelationshipStatus?
  crmInteractions       CrmInteraction[]
  crmTasks              CrmTask[]
  crmOpportunities      CrmOpportunity[]

  @@index([name])
}

model Transaction {
  id                    String            @id @default(uuid())
  sumupId               String?           @unique
  receiptId             String?
  transactionCode       String            @unique
  totalAmount           Decimal           @db.Decimal(10, 2)
  invoiceType           String            @default("issued")
  supplierId            String?
  supplierName          String?
  supplierICO           String?
  supplierDIC           String?
  supplierAddress       String?
  customerId            String?
  customerName          String?
  customerICO           String?
  customerDIC           String?
  customerAddress       String?
  paymentType           String
  status                String            @default("completed")
  transactionDate       DateTime          @default(now())
  note                  String?
  attachmentUrl         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  sumupTransactionCode  String?
  totalAmountWithoutVat Decimal           @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal           @default(0) @db.Decimal(10, 2)
  deliveryNote          DeliveryNote?
  inventoryItems        InventoryItem[]
  issuedInvoice         IssuedInvoice?
  customer              Customer?         @relation(fields: [customerId], references: [id])
  supplier              Supplier?         @relation(fields: [supplierId], references: [id])
  items                 TransactionItem[]

  @@index([transactionCode])
  @@index([transactionDate])
  @@index([customerId])
  @@index([supplierId])
  @@index([invoiceType])
  @@index([transactionDate, invoiceType])
  @@index([transactionDate, status])
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String?
  productName   String?
  quantity      Decimal     @db.Decimal(10, 3)
  unit          String
  price         Decimal?    @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  priceWithVat  Decimal?    @db.Decimal(10, 2)
  vatAmount     Decimal?    @db.Decimal(10, 2)
  vatRate       Decimal     @default(21) @db.Decimal(5, 2)
  product       Product?    @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([productId])
}

model Settings {
  id                        String   @id @default("default")
  companyName               String   @default("")
  ico                       String   @default("")
  dic                       String   @default("")
  address                   String   @default("")
  phone                     String   @default("")
  email                     String   @default("")
  bankAccount               String   @default("")
  logo                      String?
  lastIssuedInvoiceNumber   Int      @default(0)
  lastIssuedInvoiceYear     Int      @default(0)
  lastReceivedInvoiceNumber Int      @default(0)
  lastPurchaseOrderNumber   Int      @default(0)
  lastPurchaseOrderYear     Int      @default(0)
  lastReceiptNumber         Int      @default(0)
  lastReceiptYear           Int      @default(0)
  lastDeliveryNoteNumber    Int      @default(0)
  lastDeliveryNoteYear      Int      @default(0)
  lastCustomerOrderNumber   Int      @default(0)
  lastCustomerOrderYear     Int      @default(0)
  allowNegativeStock        Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  lastTransactionNumber     Int      @default(0)
  lastTransactionYear       Int      @default(0)
  defaultVatRate            Decimal  @default(21) @db.Decimal(5, 2)
  isVatPayer                Boolean  @default(true)
  eshopApiKey               String   @default("")
}

model PurchaseOrder {
  id                    String              @id @default(uuid())
  orderNumber           String              @unique
  supplierId            String?
  supplierName          String?
  supplierICO           String?
  supplierDIC           String?
  supplierAddress       String?
  orderDate             DateTime            @default(now())
  expectedDate          DateTime?
  note                  String?
  status                String              @default("pending")
  pdfPath               String?
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  supplierBankAccount   String?
  supplierContactPerson String?
  supplierEmail         String?
  supplierPhone         String?
  supplierWebsite       String?
  supplierEntityType    String?
  discountAmount        Decimal?            @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?            @db.Decimal(10, 2)
  totalAmount           Decimal?            @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal?            @db.Decimal(10, 2)
  totalVatAmount        Decimal?            @db.Decimal(10, 2)
  supplier              Supplier?           @relation(fields: [supplierId], references: [id])
  items                 PurchaseOrderItem[]
  receipts              Receipt[]
  invoice               ReceivedInvoice?

  @@index([orderNumber])
  @@index([supplierId])
  @@index([orderDate])
  @@index([status])
}

model PurchaseOrderItem {
  id                      String        @id @default(uuid())
  purchaseOrderId         String
  productId               String?
  productName             String?
  quantity                Decimal       @db.Decimal(10, 3)
  alreadyReceivedQuantity Decimal       @default(0) @db.Decimal(10, 3)
  unit                    String
  expectedPrice           Decimal?      @db.Decimal(10, 2)
  createdAt               DateTime      @default(now())
  priceWithVat            Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount               Decimal       @default(0) @db.Decimal(10, 2)
  vatRate                 Decimal       @default(21) @db.Decimal(5, 2)
  product                 Product?      @relation(fields: [productId], references: [id])
  purchaseOrder           PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}

model Receipt {
  id                String           @id @default(uuid())
  receiptNumber     String           @unique
  purchaseOrderId   String?
  supplierId        String?
  supplierName      String?
  supplierICO       String?
  supplierDIC       String?
  supplierAddress   String?
  receiptDate       DateTime         @default(now())
  note              String?
  status            String           @default("draft")
  pdfPath           String?
  processedAt       DateTime?
  stornoReason      String?
  stornoAt          DateTime?
  stornoBy          String?
  receivedInvoiceId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  inventoryItems    InventoryItem[]
  purchaseOrder     PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  receivedInvoice   ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id])
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  items             ReceiptItem[]

  @@index([receiptNumber])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([receivedInvoiceId])
  @@index([receiptDate])
  @@index([status])
}

model ReceiptItem {
  id               String         @id @default(uuid())
  receiptId        String
  productId        String?
  productName      String?
  quantity         Decimal        @db.Decimal(10, 3)
  receivedQuantity Decimal?       @db.Decimal(10, 3)
  unit             String
  purchasePrice    Decimal        @db.Decimal(10, 2)
  inventoryItemId  String?
  batchId          String?
  createdAt        DateTime       @default(now())
  priceWithVat     Decimal        @default(0) @db.Decimal(10, 2)
  vatAmount        Decimal        @default(0) @db.Decimal(10, 2)
  vatRate          Decimal        @default(21) @db.Decimal(5, 2)
  batch            Batch?         @relation(fields: [batchId], references: [id])
  inventoryItem    InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  product          Product?       @relation(fields: [productId], references: [id])
  receipt          Receipt        @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([productId])
  @@index([batchId])
  @@index([inventoryItemId])
}

model ReceivedInvoice {
  id                    String         @id @default(uuid())
  invoiceNumber         String         @unique
  purchaseOrderId       String?        @unique
  isTemporary           Boolean        @default(false)
  invoiceDate           DateTime
  dueDate               DateTime?
  totalAmount           Decimal        @db.Decimal(10, 2)
  paymentType           String         @default("transfer")
  attachmentUrl         String?
  note                  String?
  status                String         @default("active")
  pdfPath               String?
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  supplierAddress       String?
  supplierBankAccount   String?
  supplierContactPerson String?
  supplierDic           String?
  supplierEmail         String?
  supplierIco           String?
  supplierName          String?
  supplierPhone         String?
  supplierWebsite       String?
  constantSymbol        String?
  specificSymbol        String?
  variableSymbol        String?
  supplierEntityType    String?        @default("company")
  supplierNote          String?
  discountAmount        Decimal?       @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?       @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal        @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal        @default(0) @db.Decimal(10, 2)
  receipts              Receipt[]
  purchaseOrder         PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([invoiceNumber])
  @@index([purchaseOrderId])
  @@index([invoiceDate])
  @@index([isTemporary])
}

model DeliveryNote {
  id              String             @id @default(uuid())
  deliveryNumber  String             @unique
  transactionId   String?            @unique
  customerOrderId String?
  customerId      String?
  customerName    String?
  deliveryDate    DateTime           @default(now())
  note            String?
  status          String             @default("draft")
  pdfPath         String?
  processedAt     DateTime?
  stornoReason    String?
  stornoAt        DateTime?
  stornoBy        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  customer        Customer?          @relation(fields: [customerId], references: [id])
  customerOrder   CustomerOrder?     @relation(fields: [customerOrderId], references: [id])
  transaction     Transaction?       @relation(fields: [transactionId], references: [id])
  items           DeliveryNoteItem[]
  issuedInvoice   IssuedInvoice?

  @@index([deliveryNumber])
  @@index([transactionId])
  @@index([customerOrderId])
  @@index([customerId])
  @@index([deliveryDate])
  @@index([status])
}

model DeliveryNoteItem {
  id              String         @id @default(uuid())
  deliveryNoteId  String
  productId       String?
  productName     String?
  quantity        Decimal        @db.Decimal(10, 3)
  orderedQuantity Decimal?       @db.Decimal(10, 3)
  unit            String
  inventoryItemId String?
  // Cena uložená v momentě vytvoření výdejky — zdroj pravdy je faktura
  price           Decimal?       @db.Decimal(10, 2)   // bez DPH / ks
  priceWithVat    Decimal?       @db.Decimal(10, 2)   // s DPH / ks
  vatAmount       Decimal?       @db.Decimal(10, 2)   // DPH / ks
  vatRate         Decimal?       @db.Decimal(5, 2)    // sazba DPH
  priceSource     String?        // "invoice" | "order_item" | "product" | "manual"
  // Variant fulfillment — stores base-unit quantity when item has a variant (e.g. 7 g from a 3×5g order)
  baseQuantity    Decimal?       @db.Decimal(10, 3)
  baseUnit        String?
  createdAt       DateTime       @default(now())
  deliveryNote    DeliveryNote   @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  product         Product?       @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
  @@index([productId])
  @@index([inventoryItemId])
}

model CustomerOrder {
  id                    String              @id @default(uuid())
  orderNumber           String              @unique

  customerId            String?
  customerName          String?
  customerEmail         String?
  customerPhone         String?
  customerAddress       String?
  orderDate             DateTime            @default(now())
  totalAmount           Decimal             @db.Decimal(10, 2)
  note                  String?
  status                String              @default("new")
  pdfPath               String?
  pdfVersionCount       Int                 @default(0)
  paidAt                DateTime?
  shippedAt             DateTime?
  sumupTransactionId    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  stornoAt              DateTime?
  stornoBy              String?
  stornoReason          String?
  customerEntityType    String?
  discountAmount        Decimal?            @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?            @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal             @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal             @default(0) @db.Decimal(10, 2)
  eshopOrderId          String?             @unique
  source                String              @default("internal")
  eshopAddressId        String?
  eshopUserId           String?
  stripePaymentIntent   String?
  stripeSessionId       String?             @unique
  trackingNumber        String?
  carrier               String?
  paymentReference      String?
  // ── Shipping snapshot — immutable after order creation ────────────────────
  shippingMethod        String?   // DPD_HOME | DPD_PICKUP | ZASILKOVNA_HOME | ZASILKOVNA_PICKUP
  pickupPointId         String?   // External carrier branch ID (Zásilkovna/DPD)
  pickupPointName       String?   // Human-readable pickup point name
  pickupPointAddress    String?   // Full formatted address of pickup point
  pickupPointCarrier    String?   // "zasilkovna" | "dpd"
  // ── Billing address snapshot — immutable after order creation ─────────────
  // Null = billing same as customerAddress (delivery address)
  billingName           String?
  billingCompany        String?
  billingIco            String?
  billingDic            String?
  billingStreet         String?
  billingCity           String?
  billingZip            String?
  billingCountry        String?
  customer              Customer?           @relation(fields: [customerId], references: [id])
  EshopUser             EshopUser?          @relation(fields: [eshopUserId], references: [id])
  items                 CustomerOrderItem[]
  deliveryNotes         DeliveryNote[]
  issuedInvoice         IssuedInvoice?
  reservations          Reservation[]
  webhookLogs           EshopWebhookLog[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([orderDate])
  @@index([status])
  @@index([sumupTransactionId])
  @@index([eshopUserId])
  @@index([source])
  @@index([stripeSessionId])
  @@index([eshopOrderId])
  @@index([shippingMethod])
  @@index([pickupPointCarrier])
  @@index([createdAt, status])
  @@index([paidAt])
  @@index([customerId, createdAt])
}

model CustomerOrderItem {
  id              String        @id @default(uuid())
  customerOrderId String
  productId       String?
  productName     String?
  quantity        Decimal       @db.Decimal(10, 3)
  shippedQuantity Decimal       @default(0) @db.Decimal(10, 3)
  shippedBaseQty  Decimal       @default(0) @db.Decimal(10, 3)
  unit            String
  variantValue    Decimal?      @db.Decimal(10, 3)
  variantUnit     String?
  price           Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  priceWithVat    Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  vatRate         Decimal       @default(21) @db.Decimal(5, 2)
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@index([customerOrderId])
  @@index([productId])
}

model Reservation {
  id              String        @id @default(uuid())
  customerOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(10, 3)
  unit            String
  variantValue    Decimal?      @db.Decimal(10, 3)
  variantUnit     String?
  status          String        @default("active")
  createdAt       DateTime      @default(now())
  cancelledAt     DateTime?
  fulfilledAt     DateTime?
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
  @@index([productId])
  @@index([status])
}

model IssuedInvoice {
  id                    String              @id @default(uuid())
  invoiceNumber         String              @unique
  transactionId         String?             @unique
  customerOrderId       String?             @unique
  deliveryNoteId        String?             @unique
  customerId            String?
  customerName          String?
  invoiceDate           DateTime            @default(now())
  dueDate               DateTime?
  totalAmount           Decimal             @db.Decimal(10, 2)
  paymentType           String              @default("card")
  paymentStatus         String              @default("paid")
  note                  String?
  status                String              @default("active")
  pdfPath               String?
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  constantSymbol        String?
  specificSymbol        String?
  variableSymbol        String?
  customerAddress       String?
  customerBankAccount   String?
  customerContactPerson String?
  customerDic           String?
  customerEmail         String?
  customerIco           String?
  customerPhone         String?
  customerWebsite       String?
  customerEntityType    String?
  discountAmount        Decimal?            @db.Decimal(10, 2)
  discountType          String?
  discountValue         Decimal?            @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal             @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal             @default(0) @db.Decimal(10, 2)
  creditNotes           CreditNote[]
  customer              Customer?           @relation(fields: [customerId], references: [id])
  customerOrder         CustomerOrder?      @relation(fields: [customerOrderId], references: [id])
  deliveryNote          DeliveryNote?       @relation(fields: [deliveryNoteId], references: [id])
  transaction           Transaction?        @relation(fields: [transactionId], references: [id])
  items                 IssuedInvoiceItem[]

  @@index([invoiceNumber])
  @@index([transactionId])
  @@index([customerOrderId])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@index([status])
  @@index([invoiceDate, paymentStatus])
  @@index([dueDate, paymentStatus])
  @@index([customerId, invoiceDate])
}

model IssuedInvoiceItem {
  id              String        @id @default(uuid())
  issuedInvoiceId String
  productId       String?
  productName     String?
  quantity        Decimal       @db.Decimal(10, 3)
  unit            String
  price           Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  priceWithVat    Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 2)
  vatRate         Decimal       @default(21) @db.Decimal(5, 2)
  issuedInvoice   IssuedInvoice @relation(fields: [issuedInvoiceId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@index([issuedInvoiceId])
  @@index([productId])
}

model CreditNote {
  id                    String           @id @default(uuid())
  creditNoteNumber      String           @unique
  issuedInvoiceId       String
  customerId            String?
  customerName          String?
  customerEntityType    String?
  customerEmail         String?
  customerPhone         String?
  customerAddress       String?
  customerIco           String?
  customerDic           String?
  creditNoteDate        DateTime         @default(now())
  totalAmount           Decimal          @db.Decimal(10, 2)
  totalAmountWithoutVat Decimal          @default(0) @db.Decimal(10, 2)
  totalVatAmount        Decimal          @default(0) @db.Decimal(10, 2)
  reason                String?
  note                  String?
  status                String           @default("active")
  pdfPath               String?
  stornoReason          String?
  stornoAt              DateTime?
  stornoBy              String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  issuedInvoice         IssuedInvoice    @relation(fields: [issuedInvoiceId], references: [id], onDelete: Cascade)
  items                 CreditNoteItem[]

  @@index([creditNoteNumber])
  @@index([issuedInvoiceId])
  @@index([customerId])
  @@index([creditNoteDate])
  @@index([status])
}

model CreditNoteItem {
  id           String     @id @default(uuid())
  creditNoteId String
  productId    String?
  productName  String?
  quantity     Decimal    @db.Decimal(10, 3)
  unit         String
  price        Decimal    @db.Decimal(10, 2)
  vatRate      Decimal    @default(21) @db.Decimal(5, 2)
  vatAmount    Decimal    @default(0) @db.Decimal(10, 2)
  priceWithVat Decimal    @default(0) @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model DocumentSeries {
  id           String   @id @default(uuid())
  documentType String
  year         Int
  lastNumber   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([documentType, year])
  @@index([documentType])
}

model Inventura {
  id               String          @id @default(uuid())
  inventuraNumber  String          @unique
  inventuraDate    DateTime        @default(now())
  note             String?
  totalProducts    Int             @default(0)
  checkedProducts  Int             @default(0)
  differencesCount Int             @default(0)
  surplusCount     Int             @default(0)
  shortageCount    Int             @default(0)
  status           String          @default("completed")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            InventuraItem[]

  @@index([inventuraNumber])
  @@index([inventuraDate])
  @@index([status])
}

model InventuraItem {
  id             String    @id @default(uuid())
  inventuraId    String
  productId      String
  productName    String
  unit           String
  category       String?
  systemStock    Decimal   @db.Decimal(10, 3)
  actualStock    Decimal   @db.Decimal(10, 3)
  difference     Decimal   @db.Decimal(10, 3)
  differenceType String    @default("none")
  createdAt      DateTime  @default(now())
  inventura      Inventura @relation(fields: [inventuraId], references: [id], onDelete: Cascade)

  @@index([inventuraId])
  @@index([productId])
}

model BlogPost {
  id          String    @id
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  @@index([published])
  @@index([slug])
}

model EshopAddress {
  id         String    @id
  userId     String
  fullName   String
  line1      String
  line2      String?
  city       String
  postalCode String
  country    String    @default("CZ")
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  EshopUser  EshopUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EshopCart {
  id            String          @id
  userId        String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  EshopUser     EshopUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  EshopCartItem EshopCartItem[]
}

model EshopCartItem {
  id        String    @id
  cartId    String
  productId String
  quantity  Int       @default(1)
  EshopCart EshopCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model EshopEmailVerificationToken {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  EshopUser EshopUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EshopPasswordResetToken {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  EshopUser EshopUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EshopSetting {
  key       String   @id
  value     String
  updatedAt DateTime
}

model EshopUser {
  id                          String                        @id
  email                       String                        @unique
  name                        String?
  phone                       String?
  passwordHash                String?
  role                        String                        @default("CUSTOMER")
  emailVerified               DateTime?
  newsletter                  Boolean                       @default(false)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime
  CustomerOrder               CustomerOrder[]
  EshopAddress                EshopAddress[]
  EshopCart                   EshopCart?
  EshopEmailVerificationToken EshopEmailVerificationToken[]
  EshopPasswordResetToken     EshopPasswordResetToken[]

  @@index([email])
}

model ShippingMethod {
  id            String   @id
  name          String
  provider      String   @default("custom")
  description   String?
  price         Int      @default(0)
  freeThreshold Int?
  codFee        Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  estimatedDays String   @default("2-3")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ========== UŽIVATELÉ (PŘIHLÁŠENÍ DO ERP) ==========
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userRoles    UserRole[]
  auditLogs    AuditLog[]

  // CRM back-relations
  crmContactsCreated       CrmContact[]            @relation("CrmContactCreatedBy")
  crmRelationshipsOwned    CrmRelationshipStatus[] @relation("CrmAccountOwner")
  crmInteractionsCreated   CrmInteraction[]        @relation("CrmInteractionCreatedBy")
  crmTasksAssigned         CrmTask[]               @relation("CrmTaskAssignee")
  crmTasksCreated          CrmTask[]               @relation("CrmTaskCreatedBy")
  crmOpportunitiesOwned    CrmOpportunity[]        @relation("CrmOpportunityOwner")
  crmOpportunitiesCreated  CrmOpportunity[]        @relation("CrmOpportunityCreatedBy")

  @@index([email])
}

// ========== RBAC — ROLE, OPRÁVNĚNÍ ==========

model Role {
  id              String           @id @default(uuid())
  name            String           @unique  // ADMIN | ACCOUNTANT | WAREHOUSE | MANAGER
  displayName     String
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([name])
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  displayName     String
  module          String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@index([name])
  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ========== AUDIT LOG ==========

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  username   String?
  role       String?
  actionType String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | EXPORT
  entityName String?
  entityId   String?
  fieldName  String?
  oldValue   String?
  newValue   String?
  module     String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actionType])
  @@index([entityName])
  @@index([entityId])
  @@index([module])
  @@index([createdAt])
}

// ========== API KLÍČE PRO EXTERNÍ PŘÍSTUP (E-SHOP) ==========
// ========== VARIANTY PRODUKTŮ PRO ESHOP (spravováno z ERP) ==========
model EshopVariant {
  id           String   @id @default(uuid())
  productId    String
  name         String
  price        Decimal  @db.Decimal(10, 2)
  variantValue Float?   // Množství na variantu (100, 30, 3.5 …)
  variantUnit  String?  // Jednotka varianty: "g" | "ml" | "ks" — null zdědí Product.unit
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  isSumup      Boolean  @default(false) // true = tato varianta je napojena na SumUp sync
  // ── Product identification (SKU/EAN) ────────────────────────────────────────
  // sku: required per variant in business logic; nullable at DB level so existing rows
  //      remain valid without migration back-fill — API layer enforces the constraint.
  sku          String?  @unique // SKU (Stock Keeping Unit) — unique across all variants
  ean          String?  @unique // EAN/GTIN barcode — optional, validated as EAN-8/13/14
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sku])
  @@index([ean])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String    // Popis klíče (např. "Eshop Weedej na Vercelu")
  key        String    @unique // Samotný API klíč (erp_live_xxxx...)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([key])
}

// ========== ANALYTICS — EVENTS Z E-SHOPU ==========

model AnalyticsEvent {
  id               String   @id @default(uuid())
  eventId          String   @unique // client UUID sent by e-shop — used for deduplication
  eventType        String   // product_view | add_to_cart | begin_checkout | purchase | refund | signup
  entityType       String?  // "product" | "order" | "customer"
  entityId         String?  // ID entity (eshop orderId, productId, …)
  userId           String?  // e-shop User.id (string, not FK — separate DB)
  sessionId        String?  // browser session identifier

  // Browser context — captured by e-shop, forwarded for server-side provider enrichment
  gaClientId       String?  // GA4 _ga cookie → client_id for Measurement Protocol
  fbp              String?  // Meta _fbp cookie
  fbc              String?  // Meta _fbc click-ID cookie

  // ERP enrichment — filled at ingestion time if a match is found
  erpCustomerId    String?  // matched ERP Customer.id
  erpOrderId       String?  // matched ERP CustomerOrder.id

  source           String   // "eshop" | "erp" | "api"
  properties       Json     // event-specific payload (revenue, items, currency …)
  ipAddress        String?
  userAgent        String?

  // UTM / attribution context — denormalised from AnalyticsSession for fast aggregations
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?
  referrer         String?
  landingPage      String?

  clientTimestamp  DateTime // when the event occurred on the e-shop (sent by client)
  createdAt        DateTime @default(now()) // when ERP received it

  deliveries       AnalyticsEventDelivery[]

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([source, createdAt])
  @@index([erpCustomerId, createdAt])
  @@index([erpOrderId])
  @@index([createdAt])
  @@index([utmSource, createdAt])
  @@index([utmCampaign, createdAt])
  @@index([sessionId, eventType])
}

model AnalyticsEventDelivery {
  id               String         @id @default(uuid())
  analyticsEventId String
  provider         String         // "ga4" | "meta"
  status           String         @default("pending")
  // pending | delivered | failed | skipped | permanently_failed
  attempts         Int            @default(0)
  lastAttemptAt    DateTime?
  httpStatus       Int?           // HTTP response code from the provider
  responseBody     Json?          // provider response body (for debugging)
  errorMessage     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  event            AnalyticsEvent @relation(fields: [analyticsEventId], references: [id], onDelete: Cascade)

  @@index([analyticsEventId])
  @@index([provider, status])
  @@index([status, createdAt])
  @@index([status, attempts, lastAttemptAt])
}

// ========== ANALYTICS SESSION ==========
// One record per browser session. Created on session_start event.
// UTMs are stored here (source of truth) and denormalised to AnalyticsEvent for fast querying.
model AnalyticsSession {
  id           String    @id @default(uuid())
  sessionId    String    @unique  // matches AnalyticsEvent.sessionId

  // Attribution UTMs
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  referrer     String?
  landingPage  String?

  // Browser identifiers
  gaClientId   String?
  fbp          String?
  fbc          String?
  ipAddress    String?
  userAgent    String?

  // ERP enrichment
  erpCustomerId String?  // set when purchase is matched to a customer
  userId        String?  // e-shop user ID

  firstSeen    DateTime  @default(now())
  lastSeen     DateTime  @updatedAt

  @@index([utmSource, firstSeen])
  @@index([utmCampaign, firstSeen])
  @@index([erpCustomerId])
  @@index([userId])
  @@index([firstSeen])
}

// ========== WEBHOOK LOGY (ERP → E-SHOP) ==========
model EshopWebhookLog {
  id              String        @id @default(uuid())
  customerOrderId String
  eshopOrderId    String
  erpOrderNumber  String
  event           String        @default("order-shipped")
  targetUrl       String
  payload         String        // JSON stringified (no PII)
  payloadHash     String        // SHA-256 of payload for tamper detection
  attemptCount    Int           @default(0)
  lastAttemptAt   DateTime?
  lastHttpStatus  Int?
  lastError       String?
  nextRetryAt     DateTime?
  // pending | delivered | retrying | dead
  status          String        @default("pending")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
  @@index([eshopOrderId])
  @@index([status])
  @@index([nextRetryAt])
}

// ========== CRM — RELATIONSHIP CONTEXT ==========

model CrmContact {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String?
  role        String?   // e.g. "CEO", "Procurement Manager"
  email       String?
  phone       String?
  isPrimary   Boolean   @default(false)
  note        String?
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  createdBy   User?     @relation("CrmContactCreatedBy", fields: [createdById], references: [id])

  interactions CrmInteraction[]
  tasks        CrmTask[]

  @@index([customerId])
  @@map("crm_contacts")
}

model CrmRelationshipStatus {
  id         String   @id @default(uuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // lead | prospect | active | at_risk | churned | inactive
  stage          String    @default("prospect")
  healthScore    Int?
  ownerId        String?
  owner          User?     @relation("CrmAccountOwner", fields: [ownerId], references: [id])

  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  updatedAt       DateTime  @updatedAt

  @@map("crm_relationship_status")
}

// ========== CRM — ACTIVITY CONTEXT ==========

model CrmInteraction {
  id            String      @id @default(uuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       CrmContact? @relation(fields: [contactId], references: [id])

  // call | email | meeting | note | visit | demo | other
  type          String
  // inbound | outbound — null for notes/meetings
  direction     String?
  subject       String
  body          String?     @db.Text
  outcome       String?
  occurredAt    DateTime
  durationMin   Int?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdById   String?
  createdBy     User?       @relation("CrmInteractionCreatedBy", fields: [createdById], references: [id])

  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id])

  @@index([customerId, occurredAt(sort: Desc)])
  @@index([opportunityId])
  @@map("crm_interactions")
}

model CrmTask {
  id          String      @id @default(uuid())
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     CrmContact? @relation(fields: [contactId], references: [id])

  title       String
  description String?   @db.Text
  // call_back | send_email | follow_up | demo | send_quote | other
  type        String    @default("follow_up")
  // open | in_progress | done | cancelled
  status      String    @default("open")
  // low | normal | high | urgent
  priority    String    @default("normal")
  dueAt       DateTime?
  completedAt DateTime?

  assignedToId String?
  assignedTo   User?    @relation("CrmTaskAssignee", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User?    @relation("CrmTaskCreatedBy", fields: [createdById], references: [id])

  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, dueAt])
  @@index([assignedToId, status])
  @@map("crm_tasks")
}

// ========== CRM — PIPELINE CONTEXT ==========

model CrmOpportunity {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title           String
  description     String?   @db.Text
  value           Decimal?  @db.Decimal(12, 2)
  currency        String    @default("CZK")
  probability     Int?

  // lead | qualified | proposal | negotiation | won | lost
  stage           String    @default("lead")
  lostReason      String?

  expectedCloseAt DateTime?
  closedAt        DateTime?

  ownerId     String?
  owner       User?    @relation("CrmOpportunityOwner", fields: [ownerId], references: [id])
  createdById String?
  createdBy   User?    @relation("CrmOpportunityCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interactions CrmInteraction[]
  tasks        CrmTask[]

  @@index([customerId])
  @@index([stage, expectedCloseAt])
  @@map("crm_opportunities")
}
