# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ucetni_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL="https://your-erp-domain.com"

# SumUp API — key is stored encrypted in DB via Settings → API klíče → SumUp.
# SUMUP_API_KEY is a legacy fallback; remove after saving the key through the UI.
SUMUP_API_KEY="sup_sk_REPLACE_WITH_YOUR_KEY"
SUMUP_API_URL="https://api.sumup.com/v0.1"

# AES-256-GCM encryption key for third-party API credentials stored in DB.
# Must be exactly 64 hex chars (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS"

# Cron
CRON_SECRET="your-cron-secret-here"

# Webhook
ERP_WEBHOOK_SECRET="your-webhook-secret-here"

# Eshop integration
ESHOP_URL="https://your-eshop-domain.com"
