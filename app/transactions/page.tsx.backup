// Stránka transakcí (/transactions)
// Zobrazení všech transakcí + manuální přidání + kalendář + mazání

'use client'

import { useEffect, useState } from 'react'
import { useSearchParams } from 'next/navigation'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/Card'
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '@/components/ui/Table'
import Button from '@/components/ui/Button'
import Input from '@/components/ui/Input'
import { formatPrice, formatQuantity, formatDateTime } from '@/lib/utils'
import { RefreshCw, ChevronDown, ChevronRight, Plus, X, Trash2, Calendar } from 'lucide-react'

interface TransactionItem {
  id: string
  quantity: number
  unit: string
  price: number | null
  product: {
    id: string
    name: string
  }
}

interface Transaction {
  id: string
  transactionCode: string
  totalAmount: number
  paymentType: string
  status: string
  transactionDate: string
  items: TransactionItem[]
  customer?: {
    id: string
    name: string
  } | null
}

interface Product {
  id: string
  name: string
  price: number
  unit: string
  category?: {
    id: string
    name: string
  } | null
}

interface Customer {
  id: string
  name: string
}

export default function TransactionsPage() {
  const searchParams = useSearchParams()
  const highlightId = searchParams.get('highlight')

  const [transactions, setTransactions] = useState<Transaction[]>([])
  const [products, setProducts] = useState<Product[]>([])
  const [customers, setCustomers] = useState<Customer[]>([])
  const [loading, setLoading] = useState(true)
  const [syncing, setSyncing] = useState(false)
  const [expandedTransactions, setExpandedTransactions] = useState<Set<string>>(new Set())
  const [selectedTransactions, setSelectedTransactions] = useState<Set<string>>(new Set())
  const [showForm, setShowForm] = useState(false)
  const [showSyncForm, setShowSyncForm] = useState(false)
  const [editingTransaction, setEditingTransaction] = useState<Transaction | null>(null)

  // Formulář pro synchronizaci
  const [syncFromDate, setSyncFromDate] = useState(
    new Date().toISOString().split('T')[0] // Dnešní datum
  )

  // Formulář pro manuální přidání transakce (faktury)
  const [formData, setFormData] = useState({
    date: new Date().toISOString().split('T')[0],
    paymentType: 'cash',
    totalAmount: '',
    customerId: '', // Pro FA faktury
  })

  // Položky transakce (více produktů)
  const [transactionItems, setTransactionItems] = useState<Array<{
    productId: string
    quantity: string
  }>>([])

  // Aktuální produkt k přidání
  const [currentItem, setCurrentItem] = useState({
    productId: '',
    quantity: '',
  })

  useEffect(() => {
    fetchData()
  }, [])

  // Automaticky rozbal a scrolluj k highlightnuté transakci
  useEffect(() => {
    if (highlightId && transactions.length > 0) {
      // Rozbal transakci
      setExpandedTransactions(new Set([highlightId]))

      // Scrolluj k transakci po malé pauze (aby se stránka načetla)
      setTimeout(() => {
        const element = document.getElementById(`transaction-${highlightId}`)
        if (element) {
          element.scrollIntoView({ behavior: 'smooth', block: 'center' })
          // Přidej highlight efekt
          element.classList.add('bg-blue-50')
          setTimeout(() => {
            element.classList.remove('bg-blue-50')
          }, 2000)
        }
      }, 100)
    }
  }, [highlightId, transactions])

  async function fetchData() {
    try {
      const [transactionsRes, productsRes, customersRes] = await Promise.all([
        fetch('/api/transactions'),
        fetch('/api/products'),
        fetch('/api/customers'),
      ])
      const transactionsData = await transactionsRes.json()
      const productsData = await productsRes.json()
      const customersData = await customersRes.json()
      setTransactions(transactionsData)
      setProducts(productsData)
      setCustomers(customersData)
    } catch (error) {
      console.error('Chyba při načítání dat:', error)
    } finally {
      setLoading(false)
    }
  }

  // Synchronizovat transakce ze SumUp
  async function handleSync() {
    setSyncing(true)
    try {
      const endDate = new Date()
      const startDate = new Date(syncFromDate)

      const response = await fetch('/api/transactions/sync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          startDate: startDate.toISOString(),
          endDate: endDate.toISOString(),
        }),
      })

      const data = await response.json()
      alert(`Synchronizováno ${data.transactions?.length || 0} nových transakcí`)

      await fetchData()
      setShowSyncForm(false)
    } catch (error) {
      console.error('Chyba při synchronizaci:', error)
      alert('Nepodařilo se synchronizovat transakce')
    } finally {
      setSyncing(false)
    }
  }

  // Přidat položku do transakce
  function handleAddItem() {
    if (!currentItem.productId || !currentItem.quantity) {
      alert('Vyber produkt a zadej množství')
      return
    }

    setTransactionItems([...transactionItems, { ...currentItem }])
    setCurrentItem({ productId: '', quantity: '' })
  }

  // Odebrat položku z transakce
  function handleRemoveItem(index: number) {
    setTransactionItems(transactionItems.filter((_, i) => i !== index))
  }

  // Otevřít formulář pro přidání faktury
  function handleOpenForm() {
    setEditingTransaction(null)
    setFormData({
      date: new Date().toISOString().split('T')[0], // Vždy dnešní datum
      paymentType: 'cash',
      totalAmount: '',
      customerId: '',
    })
    setTransactionItems([])
    setCurrentItem({ productId: '', quantity: '' })
    setShowForm(true)
  }

  // Otevřít formulář pro úpravu transakce (doplnit položky)
  function handleEditTransaction(transaction: Transaction) {
    setEditingTransaction(transaction)
    setFormData({
      date: transaction.transactionDate.split('T')[0],
      paymentType: transaction.paymentType,
      totalAmount: transaction.totalAmount.toString(),
      customerId: transaction.customer?.id || '',
    })
    // Načti existující položky
    setTransactionItems(transaction.items.map(item => ({
      productId: item.product.id,
      quantity: item.quantity.toString(),
    })))
    setCurrentItem({ productId: '', quantity: '' })
    setShowForm(true)
  }

  // Otevřít formulář pro synchronizaci
  function handleOpenSyncForm() {
    setSyncFromDate(new Date().toISOString().split('T')[0]) // Vždy dnešní datum
    setShowSyncForm(true)
  }

  // Přidat transakci manuálně
  async function handleAddTransaction(e: React.FormEvent) {
    e.preventDefault()

    if (transactionItems.length === 0) {
      alert('Přidej alespoň jeden produkt do transakce')
      return
    }

    if (!formData.totalAmount) {
      alert('Zadej celkovou částku transakce')
      return
    }

    try {
      // Manuální transakce mají transaction ID (TR-timestamp), synchronizované mají FA číslo
      const transactionCode = `TR-${Date.now()}`

      // Připrav položky s jednotkami
      const items = transactionItems.map(item => {
        const product = products.find(p => p.id === item.productId)
        return {
          productId: item.productId,
          quantity: parseFloat(item.quantity),
          unit: product?.unit || 'ks',
        }
      })

      const response = await fetch('/api/transactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          transactionCode,
          totalAmount: parseFloat(formData.totalAmount),
          paymentType: formData.paymentType,
          transactionDate: formData.date,
          items,
        }),
      })

      if (response.ok) {
        alert('Transakce přidána!')
        setShowForm(false)
        setFormData({
          date: new Date().toISOString().split('T')[0],
          paymentType: 'cash',
          totalAmount: '',
        })
        setTransactionItems([])
        setCurrentItem({ productId: '', quantity: '' })
        await fetchData()
      } else {
        alert('Chyba při přidávání transakce')
      }
    } catch (error) {
      console.error('Chyba při přidávání transakce:', error)
      alert('Chyba při přidávání transakce')
    }
  }

  // Smazat jednu transakci
  async function handleDelete(transaction: Transaction) {
    if (!confirm(`Opravdu chceš smazat transakci ${transaction.transactionCode}?`)) {
      return
    }

    try {
      const response = await fetch(`/api/transactions/${transaction.id}`, {
        method: 'DELETE',
      })

      if (response.ok) {
        alert('Transakce smazána!')
        await fetchData()
      } else {
        alert('Nepodařilo se smazat transakci')
      }
    } catch (error) {
      console.error('Chyba při mazání transakce:', error)
      alert('Nepodařilo se smazat transakci')
    }
  }

  // Hromadné mazání
  async function handleBulkDelete() {
    if (selectedTransactions.size === 0) {
      alert('Nevybral jsi žádné transakce')
      return
    }

    if (
      !confirm(
        `Opravdu chceš smazat ${selectedTransactions.size} vybraných transakcí?`
      )
    ) {
      return
    }

    try {
      const response = await fetch('/api/transactions', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: Array.from(selectedTransactions) }),
      })

      if (response.ok) {
        alert(`Smazáno ${selectedTransactions.size} transakcí!`)
        setSelectedTransactions(new Set())
        await fetchData()
      } else {
        alert('Nepodařilo se smazat transakce')
      }
    } catch (error) {
      console.error('Chyba při mazání transakcí:', error)
      alert('Nepodařilo se smazat transakce')
    }
  }

  // Toggle výběr transakce
  function toggleTransactionSelection(transactionId: string) {
    const newSelected = new Set(selectedTransactions)
    if (newSelected.has(transactionId)) {
      newSelected.delete(transactionId)
    } else {
      newSelected.add(transactionId)
    }
    setSelectedTransactions(newSelected)
  }

  // Vybrat všechny / zrušit výběr
  function toggleSelectAll() {
    if (selectedTransactions.size === transactions.length) {
      setSelectedTransactions(new Set())
    } else {
      setSelectedTransactions(new Set(transactions.map(t => t.id)))
    }
  }

  // Toggle rozbalení transakce
  function toggleExpand(transactionId: string) {
    const newExpanded = new Set(expandedTransactions)
    if (newExpanded.has(transactionId)) {
      newExpanded.delete(transactionId)
    } else {
      newExpanded.add(transactionId)
    }
    setExpandedTransactions(newExpanded)
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <p className="text-gray-500">Načítání...</p>
      </div>
    )
  }

  return (
    <div className="space-y-6">
      {/* Hlavička */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold text-gray-900">Transakce</h1>
          <p className="text-gray-500 mt-1">
            Zobrazeno {transactions.length} transakcí
          </p>
        </div>

        {/* Tlačítka */}
        <div className="flex gap-3">
          {selectedTransactions.size > 0 && (
            <Button onClick={handleBulkDelete} variant="secondary">
              <Trash2 className="h-4 w-4 mr-2" />
              Smazat vybrané ({selectedTransactions.size})
            </Button>
          )}
          <Button onClick={handleOpenForm}>
            <Plus className="h-4 w-4 mr-2" />
            Přidat transakci
          </Button>
          <Button
            onClick={handleOpenSyncForm}
            disabled={syncing}
            variant="secondary"
          >
            <RefreshCw className={`h-4 w-4 mr-2 ${syncing ? 'animate-spin' : ''}`} />
            {syncing ? 'Synchronizuji...' : 'Synchronizovat ze SumUp'}
          </Button>
        </div>
      </div>

      {/* Formulář pro synchronizaci */}
      {showSyncForm && (
        <Card>
          <CardHeader>
            <div className="flex items-center justify-between">
              <CardTitle>Synchronizovat transakce ze SumUp</CardTitle>
              <button
                onClick={() => setShowSyncForm(false)}
                className="text-gray-400 hover:text-gray-600"
              >
                <X className="h-5 w-5" />
              </button>
            </div>
          </CardHeader>
          <CardContent>
            <div className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Synchronizovat od data
                </label>
                <div className="flex gap-2 items-center">
                  <Calendar className="h-5 w-5 text-gray-400" />
                  <Input
                    type="date"
                    value={syncFromDate}
                    onChange={(e) => setSyncFromDate(e.target.value)}
                    className="flex-1"
                  />
                </div>
                <p className="text-sm text-gray-500 mt-1">
                  Synchronizují se pouze NOVÉ transakce od tohoto data do dnes
                </p>
              </div>

              <div className="flex gap-3">
                <Button onClick={handleSync} disabled={syncing}>
                  {syncing ? 'Synchronizuji...' : 'Spustit synchronizaci'}
                </Button>
                <Button
                  type="button"
                  variant="secondary"
                  onClick={() => setShowSyncForm(false)}
                >
                  Zrušit
                </Button>
              </div>
            </div>
          </CardContent>
        </Card>
      )}

      {/* Formulář pro přidání transakce */}
      {showForm && (
        <Card>
          <CardHeader>
            <div className="flex items-center justify-between">
              <CardTitle>Přidat novou transakci</CardTitle>
              <button
                onClick={() => setShowForm(false)}
                className="text-gray-400 hover:text-gray-600"
              >
                <X className="h-5 w-5" />
              </button>
            </div>
          </CardHeader>
          <CardContent>
            <form onSubmit={handleAddTransaction} className="space-y-6">
              {/* Základní info transakce */}
              <div className="grid grid-cols-3 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Datum *
                  </label>
                  <div className="flex gap-2 items-center">
                    <Calendar className="h-5 w-5 text-gray-400" />
                    <Input
                      type="date"
                      value={formData.date}
                      onChange={(e) =>
                        setFormData({ ...formData, date: e.target.value })
                      }
                      required
                      className="flex-1"
                    />
                  </div>
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Typ platby *
                  </label>
                  <select
                    value={formData.paymentType}
                    onChange={(e) =>
                      setFormData({ ...formData, paymentType: e.target.value })
                    }
                    className="w-full h-10 rounded-md border border-gray-300 px-3"
                  >
                    <option value="cash">Hotovost</option>
                    <option value="card">Karta</option>
                  </select>
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Celková částka (Kč) *
                  </label>
                  <Input
                    type="number"
                    step="0.01"
                    value={formData.totalAmount}
                    onChange={(e) =>
                      setFormData({ ...formData, totalAmount: e.target.value })
                    }
                    placeholder="140"
                    required
                  />
                </div>
              </div>

              {/* Přidávání produktů */}
              <div className="border-t pt-4">
                <h3 className="text-sm font-semibold text-gray-900 mb-3">
                  Produkty v transakci
                </h3>

                {/* Seznam přidaných produktů */}
                {transactionItems.length > 0 && (
                  <div className="mb-4 space-y-2">
                    {transactionItems.map((item, index) => {
                      const product = products.find(p => p.id === item.productId)
                      return (
                        <div
                          key={index}
                          className="flex items-center gap-3 p-3 bg-gray-50 rounded-lg"
                        >
                          <div className="flex-1">
                            <p className="font-medium text-gray-900">
                              {product?.name || 'Neznámý produkt'}
                            </p>
                            <p className="text-sm text-gray-500">
                              Množství: {item.quantity} {product?.unit || 'ks'}
                            </p>
                          </div>
                          <button
                            type="button"
                            onClick={() => handleRemoveItem(index)}
                            className="text-red-600 hover:text-red-800"
                          >
                            <Trash2 className="h-4 w-4" />
                          </button>
                        </div>
                      )
                    })}
                  </div>
                )}

                {/* Formulář pro přidání dalšího produktu */}
                <div className="grid grid-cols-3 gap-3">
                  <div className="col-span-2">
                    <label className="block text-sm font-medium text-gray-700 mb-1">
                      Produkt
                    </label>
                    <select
                      value={currentItem.productId}
                      onChange={(e) =>
                        setCurrentItem({
                          ...currentItem,
                          productId: e.target.value,
                        })
                      }
                      className="w-full h-10 rounded-md border border-gray-300 px-3"
                    >
                      <option value="">Vyberte produkt...</option>
                      {/* Produkty bez kategorie */}
                      {products.filter(p => !p.category).length > 0 && (
                        <optgroup label="Bez kategorie">
                          {products.filter(p => !p.category).map((product) => (
                            <option key={product.id} value={product.id}>
                              {product.name} - {formatPrice(product.price)}
                            </option>
                          ))}
                        </optgroup>
                      )}
                      {/* Produkty podle kategorií */}
                      {Array.from(new Set(products.filter(p => p.category).map(p => p.category!.name)))
                        .sort()
                        .map((categoryName) => (
                          <optgroup key={categoryName} label={categoryName}>
                            {products
                              .filter(p => p.category?.name === categoryName)
                              .map((product) => (
                                <option key={product.id} value={product.id}>
                                  {product.name} - {formatPrice(product.price)}
                                </option>
                              ))}
                          </optgroup>
                        ))}
                    </select>
                  </div>

                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">
                      Množství{' '}
                      {currentItem.productId &&
                        `(${products.find(p => p.id === currentItem.productId)?.unit || 'ks'})`}
                    </label>
                    <div className="flex gap-2">
                      <Input
                        type="number"
                        step="0.001"
                        value={currentItem.quantity}
                        onChange={(e) =>
                          setCurrentItem({
                            ...currentItem,
                            quantity: e.target.value,
                          })
                        }
                        placeholder="1"
                        className="flex-1"
                      />
                      <Button
                        type="button"
                        onClick={handleAddItem}
                        variant="secondary"
                        disabled={!currentItem.productId || !currentItem.quantity}
                      >
                        <Plus className="h-4 w-4" />
                      </Button>
                    </div>
                  </div>
                </div>
              </div>

              <div className="flex gap-3 justify-end border-t pt-4">
                <Button
                  type="button"
                  variant="secondary"
                  onClick={() => {
                    setShowForm(false)
                    setTransactionItems([])
                    setCurrentItem({ productId: '', quantity: '' })
                  }}
                >
                  Zrušit
                </Button>
                <Button type="submit">Přidat transakci</Button>
              </div>
            </form>
          </CardContent>
        </Card>
      )}

      {/* Tabulka transakcí */}
      <Card>
        <CardContent className="p-0">
          {transactions.length === 0 ? (
            <div className="text-center py-12">
              <p className="text-gray-500 mb-4">
                Žádné transakce. Přidej je ručně nebo synchronizuj ze SumUp API.
              </p>
              <div className="flex gap-3 justify-center">
                <Button onClick={() => setShowForm(true)}>
                  Přidat transakci
                </Button>
                <Button onClick={() => setShowSyncForm(true)} variant="secondary">
                  Synchronizovat ze SumUp
                </Button>
              </div>
            </div>
          ) : (
            <div>
              {/* Hlavička s checkboxem pro výběr všech */}
              <div className="border-b p-4 flex items-center gap-4 bg-gray-50">
                <input
                  type="checkbox"
                  checked={selectedTransactions.size === transactions.length}
                  onChange={toggleSelectAll}
                  className="rounded"
                />
                <span className="text-sm font-medium text-gray-700">
                  {selectedTransactions.size > 0
                    ? `Vybráno ${selectedTransactions.size} transakcí`
                    : 'Vybrat vše'}
                </span>
              </div>

              {/* Transakce */}
              <div className="divide-y">
                {transactions.map((transaction) => {
                  const isExpanded = expandedTransactions.has(transaction.id)
                  const isSelected = selectedTransactions.has(transaction.id)

                  return (
                    <div key={transaction.id} id={`transaction-${transaction.id}`}>
                      {/* Hlavní řádek transakce */}
                      <div className="flex items-center gap-4 p-4 hover:bg-gray-50 transition-colors">
                        {/* Checkbox */}
                        <input
                          type="checkbox"
                          checked={isSelected}
                          onChange={() => toggleTransactionSelection(transaction.id)}
                          onClick={(e) => e.stopPropagation()}
                          className="rounded"
                        />

                        {/* Rozbalit/sbalit */}
                        <button
                          onClick={() => toggleExpand(transaction.id)}
                          className="flex-shrink-0"
                        >
                          {isExpanded ? (
                            <ChevronDown className="h-5 w-5 text-gray-400" />
                          ) : (
                            <ChevronRight className="h-5 w-5 text-gray-400" />
                          )}
                        </button>

                        {/* Info o transakci */}
                        <div
                          className="flex-1 flex items-center justify-between cursor-pointer"
                          onClick={() => toggleExpand(transaction.id)}
                        >
                          <div>
                            <p className="font-semibold text-gray-900">
                              {formatDateTime(transaction.transactionDate)}
                            </p>
                            <p className="text-sm text-gray-500">
                              {transaction.transactionCode}
                            </p>
                          </div>

                          <div className="flex items-center gap-6">
                            {/* Typ platby */}
                            <span className="text-sm text-gray-600">
                              {transaction.paymentType === 'card' ? 'Karta' : 'Hotovost'}
                            </span>

                            {/* Celková cena */}
                            <p className="text-lg font-bold text-gray-900 min-w-[100px] text-right">
                              {formatPrice(transaction.totalAmount)}
                            </p>

                            {/* Status */}
                            <span
                              className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                                transaction.status === 'completed'
                                  ? 'bg-green-100 text-green-800'
                                  : 'bg-gray-100 text-gray-800'
                              }`}
                            >
                              {transaction.status === 'completed' ? 'Dokončeno' : transaction.status}
                            </span>

                            {/* Tlačítko smazat */}
                            <button
                              onClick={(e) => {
                                e.stopPropagation()
                                handleDelete(transaction)
                              }}
                              className="text-red-600 hover:text-red-800"
                              title="Smazat"
                            >
                              <Trash2 className="h-4 w-4" />
                            </button>
                          </div>
                        </div>
                      </div>

                      {/* Rozbalené položky transakce */}
                      {isExpanded && (
                        <div className="bg-gray-50 px-4 py-3 ml-16">
                          <Table>
                            <TableHeader>
                              <TableRow>
                                <TableHead>Produkt</TableHead>
                                <TableHead>Množství</TableHead>
                                <TableHead>Cena</TableHead>
                              </TableRow>
                            </TableHeader>
                            <TableBody>
                              {transaction.items.map((item, index) => (
                                <TableRow key={item.id}>
                                  <TableCell>{item.product.name}</TableCell>
                                  <TableCell>
                                    {formatQuantity(item.quantity, item.unit)}
                                  </TableCell>
                                  <TableCell>
                                    {index === 0 ? formatPrice(transaction.totalAmount) : '-'}
                                  </TableCell>
                                </TableRow>
                              ))}
                            </TableBody>
                          </Table>
                        </div>
                      )}
                    </div>
                  )
                })}
              </div>
            </div>
          )}
        </CardContent>
      </Card>
    </div>
  )
}
